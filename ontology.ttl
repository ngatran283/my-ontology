# ==============================================================
# ABSTRACT CLASSES, OBJECT PROPERTIES, DATATYPE PROPERTIES
# ==============================================================

# ==============================================================
# ABSTRACT TOP-LEVEL CLASS
# ==============================================================

prod:IndustrialConnector
    rdf:type            owl:Class ;
    rdfs:label          "Industrial Connector"@en ;
    rdfs:comment        "Abstract superclass for all industrial connector products (eCLASS segment 27 / main group 2744)."@en ;
    skos:definition     "Electrical connector used in industrial environments, typically complying with IEC 61984."@en ;
    rdfs:subClassOf     schema:Product ;
    rdfs:subClassOf     gr:ProductOrService ;
    rdfs:subClassOf     gr:SomeItems .

prod:Connector
    rdf:type            owl:Class ;
    rdfs:label          "Connector"@en ;
    rdfs:comment        "A complete connector assembly. Requires at least one housing, one insert, and electrical contacts."@en ;
    rdfs:subClassOf     prod:IndustrialConnector ;
    rdfs:subClassOf
        [ rdf:type            owl:Restriction ;
          owl:onProperty      prod:hasHousing ;
          owl:minCardinality  "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf
        [ rdf:type            owl:Restriction ;
          owl:onProperty      prod:hasInsert ;
          owl:minCardinality  "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf
        [ rdf:type            owl:Restriction ;
          owl:onProperty      prod:hasContact ;
          owl:minCardinality  "1"^^xsd:nonNegativeInteger ] .


# ==============================================================
# OBJECT PROPERTIES
# Ranges point to merged leaf classes (no -gen suffix).
# ==============================================================

prod:hasHousing
    rdf:type            owl:ObjectProperty ;
    rdfs:label          "has housing"@en ;
    rdfs:comment        "Links a connector to its housing (shell)."@en ;
    rdfs:domain         prod:Connector ;
    rdfs:range          eclass:27440202 .

prod:hasInsert
    rdf:type            owl:ObjectProperty ;
    rdfs:label          "has insert"@en ;
    rdfs:comment        "Links a connector to its contact insert."@en ;
    rdfs:domain         prod:Connector ;
    rdfs:range          eclass:27440205 .

prod:hasContact
    rdf:type            owl:ObjectProperty ;
    rdfs:label          "has contact"@en ;
    rdfs:comment        "Links a connector to its electrical contacts."@en ;
    rdfs:domain         prod:Connector ;
    rdfs:range          eclass:27440204 .

prod:hasTool
    rdf:type            owl:ObjectProperty ;
    rdfs:label          "has tool"@en ;
    rdfs:comment        "Links a connector to its required assembly or crimping tool."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          eclass:21043811 .

prod:hasAccessory
    rdf:type            owl:ObjectProperty ;
    rdfs:label          "has accessory"@en ;
    rdfs:comment        "Links a connector product to an optional accessory."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          eclass:27440210 .

prod:hasSparePart
    rdf:type            owl:ObjectProperty ;
    rdfs:label          "has spare part"@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          prod:IndustrialConnector .

prod:hasAlternative
    rdf:type            owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:label          "has alternative"@en ;
    rdfs:comment        "Links a product to a functionally equivalent alternative."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          prod:IndustrialConnector .

prod:hasSuccessor
    rdf:type            owl:ObjectProperty ;
    rdfs:label          "has successor"@en ;
    rdfs:comment        "Links a discontinued product to its replacement."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          prod:IndustrialConnector .

prod:isMatingConnectorOf
    rdf:type            owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:label          "is mating connector of"@en ;
    rdfs:comment        "Links two connectors that physically mate with each other."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          prod:IndustrialConnector .

prod:isCompatibleWith
    rdf:type            owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:label          "is compatible with"@en ;
    rdfs:comment        "Links products that are compatible."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          prod:IndustrialConnector .

prod:requiresPart
    rdf:type            owl:ObjectProperty ;
    rdfs:label          "requires part"@en ;
    rdfs:comment        "Defines that an assembly requires a specific type of part."@en ;
    rdfs:domain         prod:Connector ;
    rdfs:range          prod:IndustrialConnector .


# ==============================================================
# DATATYPE PROPERTIES
# ==============================================================

prod:size
    rdf:type            owl:DatatypeProperty ;
    rdfs:label          "size"@en ;
    rdfs:comment        "Physical size designation (e.g. 3A, 6B, 16B)."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          xsd:string .

prod:gender
    rdf:type            owl:DatatypeProperty ;
    rdfs:label          "gender"@en ;
    rdfs:comment        "Gender of the connector (male or female)."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          xsd:string .

prod:ipRating
    rdf:type            owl:DatatypeProperty ;
    rdfs:label          "IP protection rating"@en ;
    rdfs:comment        "Protection class per IEC 60529 (e.g. IP65, IP67)."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          xsd:string .

prod:productSeries
    rdf:type            owl:DatatypeProperty ;
    rdfs:label          "product series"@en ;
    rdfs:comment        "The product series or family (e.g. Han A, Han B, Han Modular)."@en ;
    rdfs:domain         prod:IndustrialConnector ;
    rdfs:range          xsd:string .